# Copy to .env in this folder (never commit .env).
# Conversational assistant runs in the browser — no chat API keys required here.

# YOLO vision (optional)
# AGRI_YOLO_WEIGHTS=/path/to/best.pt

# Optional: comma-separated CORS origins if you don't want allow-all (*):
# AGRI_CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
