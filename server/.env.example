# Copy to .env in this folder (never commit .env).

# --- LLM provider (pick one primary credential set) ---
# Auto-routing: if GITHUB_TOKEN is set, chat uses GitHub Models; else Gemini.
# Force: LLM_PROVIDER=github | LLM_PROVIDER=gemini

# GitHub Models (fine-grained PAT with "Models" / models:read):
# https://docs.github.com/github-models/quickstart
GITHUB_TOKEN=
# Examples: openai/gpt-4o, openai/gpt-4.1, microsoft/phi-4-mini-instruct, meta/llama-3.3-70b-instruct
GITHUB_MODEL=openai/gpt-4o
# GITHUB_MAX_TOKENS=2048
# GITHUB_TEMPERATURE=0.35

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Optional: comma-separated origins if you don't want allow-all (*):
# AGRI_CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
